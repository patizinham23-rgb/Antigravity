<% content_for :title, "Nova Categoria - Admin" %>

<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold gold font-serif mb-8">✦ Nova Categoria</h1>

  <%= form_with model: [:admin, @category], class: "space-y-6" do |f| %>
    <% if @category.errors.any? %>
      <div class="alert"><%= pluralize(@category.errors.count, "erro") %> impediram o salvamento</div>
    <% end %>

    <div>
      <%= f.label :name, "Nome", class: "block text-sm uppercase tracking-wider mb-1", style: "color: #a89070;" %>
      <%= f.text_field :name, placeholder: "Ex: Ourivesaria" %>
    </div>

    <div>
      <%= f.label :description, "Descrição (opcional)", class: "block text-sm uppercase tracking-wider mb-1", style: "color: #a89070;" %>
      <%= f.text_area :description, rows: 3, placeholder: "Descrição da categoria..." %>
    </div>

    <div>
      <%= f.submit "Salvar Categoria", class: "btn-gold w-full", style: "padding: 14px;" %>
    </div>
  <% end %>

  <%= link_to "← Voltar", admin_categories_path, class: "block mt-4 text-sm", style: "color: #a89070;" %>
</div>
