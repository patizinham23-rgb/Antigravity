<% content_for :title, "Usuários - Admin" %>

<div class="max-w-6xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold gold font-serif mb-8">✦ Usuários</h1>

  <div class="card-dark p-6 overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr style="color: #666; border-bottom: 1px solid #222;">
          <th class="text-left py-3">Nome</th>
          <th class="text-left py-3">Email</th>
          <th class="text-left py-3">Role</th>
          <th class="text-left py-3">Matrículas</th>
          <th class="text-left py-3">Membro desde</th>
          <th class="text-right py-3">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr style="border-bottom: 1px solid #1a1a1a;">
            <td class="py-3"><%= user.name %></td>
            <td class="py-3" style="color: #666;"><%= user.email %></td>
            <td class="py-3">
              <span class="text-xs px-2 py-1 rounded <%= user.admin? ? 'gold-bg text-black' : '' %>" style="<%= 'background: #222; color: #666;' unless user.admin? %>">
                <%= user.role.humanize %>
              </span>
            </td>
            <td class="py-3" style="color: #666;"><%= user.enrollments.count %></td>
            <td class="py-3" style="color: #666;"><%= l(user.created_at, format: :short) %></td>
            <td class="py-3 text-right">
              <%= link_to "Editar", edit_admin_user_path(user), class: "text-sm gold" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
