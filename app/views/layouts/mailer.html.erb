<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin: 0; padding: 0; background: #0a0a0a; font-family: 'Inter', Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background: #0a0a0a;">
    <tr>
      <td align="center" style="padding: 40px 20px;">
        <table width="600" cellpadding="0" cellspacing="0" style="background: #111; border-radius: 12px; border: 1px solid #222;">
          <tr>
            <td align="center" style="padding: 40px 40px 20px;">
              <h1 style="font-family: 'Playfair Display', serif; color: #c9a84c; font-size: 28px; margin: 0; letter-spacing: 4px;">✦ ANTIGRAVITY ✦</h1>
              <p style="color: #666; font-size: 12px; letter-spacing: 2px; margin-top: 8px;">LEARNING MANAGEMENT SYSTEM</p>
            </td>
          </tr>
          <tr>
            <td style="padding: 20px 40px;">
              <div style="height: 1px; background: linear-gradient(90deg, transparent, #c9a84c, transparent);"></div>
            </td>
          </tr>
          <tr>
            <td style="padding: 0 40px 40px; color: #a89070; font-size: 15px; line-height: 1.7;">
              <%= yield %>
            </td>
          </tr>
          <tr>
            <td style="padding: 20px 40px; border-top: 1px solid #1a1a1a;">
              <p style="color: #444; font-size: 12px; text-align: center; margin: 0;">
                Antigravity LMS · Todos os direitos reservados<br>
                <a href="https://antigravitylms.com" style="color: #c9a84c; text-decoration: none;">antigravitylms.com</a>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
