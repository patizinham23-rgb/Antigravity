<h2 class="text-2xl font-bold gold font-serif text-center mb-8">Entrar</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "max-w-md mx-auto space-y-4" }) do |f| %>
  <div>
    <%= f.label :email, class: "block text-sm uppercase tracking-wider mb-1", style: "color: #a89070;" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div>
    <%= f.label :password, "Senha", class: "block text-sm uppercase tracking-wider mb-1", style: "color: #a89070;" %>
    <%= f.password_field :password, autocomplete: "current-password" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="flex items-center gap-2">
      <%= f.check_box :remember_me, class: "w-4 h-4", style: "accent-color: #c9a84c;" %>
      <%= f.label :remember_me, "Lembrar-me", class: "text-sm", style: "color: #666;" %>
    </div>
  <% end %>

  <div class="pt-4">
    <%= f.submit "Entrar", class: "btn-gold w-full text-center", style: "padding: 12px;" %>
  </div>
<% end %>

<div class="text-center mt-6 space-y-2">
  <%= link_to "Criar conta", new_registration_path(resource_name), class: "text-sm gold" %>
  <br>
  <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-xs", style: "color: #666;" %>
</div>
